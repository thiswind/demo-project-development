{
  "name": "demo-project-development",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "DEMO technical validation project for local development, GitHub, GitHub Actions, GitHub Pages, Vercel deployment, and Vercel custom domain binding.",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
